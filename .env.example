# Database configuration (Neon Postgres connection string)
DATABASE_URL="postgres://user:password@host/db?sslmode=require"

# Tripay Payment Gateway Configurations
TRIPAY_API_KEY="your_tripay_api_key"
TRIPAY_PRIVATE_KEY="your_tripay_private_key"
TRIPAY_MERCHANT_CODE="your_tripay_merchant_code"
TRIPAY_MODE="sandbox" # sandbox or production

# Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin Configuration & Session Secret (32+ chars)
SESSION_SECRET="your_session_secret_at_least_32_characters_long"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="" # Generate dengan: npm run hash-password

# Cron Secret for securing expire endpoint
CRON_SECRET="your_cron_secret"

# WA Bot Integration Configurations (VPS Hook)
WA_BOT_URL="http://your-wa-bot-vps-ip:port"
WA_BOT_KEY="your_wa_bot_api_key"
